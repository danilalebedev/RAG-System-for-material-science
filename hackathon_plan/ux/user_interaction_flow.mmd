flowchart TD
    U["Пользователь: исследователь / эксперт / жюри"] --> Q["Строка запроса + режим работы"]

    Q --> M1["Режим: Найти факты"]
    Q --> M2["Режим: Сравнить эксперименты"]
    Q --> M3["Режим: Найти пробелы"]
    Q --> M4["Режим: Сформировать гипотезу"]

    M1 --> P["Query parser: intent + slots"]
    M2 --> P
    M3 --> P
    M4 --> P

    P --> S1["Материал / сплав"]
    P --> S2["Режим / процедура"]
    P --> S3["Свойство / KPI"]
    P --> S4["Ограничения: дата, лаборатория, оборудование"]

    S1 --> C{"Слотов хватает?"}
    S2 --> C
    S3 --> C
    S4 --> C

    C -- "Нет" --> CL["Уточнение: варианты из графа и справочников"]
    CL --> U2["Пользователь выбирает материал, свойство, режим или диапазон"]
    U2 --> P

    C -- "Да" --> R["Hybrid retrieval"]
    R --> R1["BM25: марки, числа, аббревиатуры"]
    R --> R2["Dense search: смысловые совпадения"]
    R --> R3["Procedure view: summaries режимов"]
    R --> R4["Graph expansion: связанные эксперименты, свойства, команды"]

    R1 --> E["Evidence pack"]
    R2 --> E
    R3 --> E
    R4 --> E

    E --> V{"Доказательств достаточно?"}
    V -- "Нет" --> GAP["Ответ: данных мало + близкие эксперименты + пробелы"]
    V -- "Да" --> A["LLM / template answer composer"]

    A --> O["Экран результата"]
    GAP --> O

    O --> T1["Answer: краткий вывод"]
    O --> T2["Evidence: документы, чанки, таблицы"]
    O --> T3["Graph: материалы-режимы-свойства"]
    O --> T4["Gaps: что не измерено / противоречит"]
    O --> T5["Benchmark: latency, recall, faithfulness"]

    T1 --> F["Действия пользователя"]
    T2 --> F
    T3 --> F
    T4 --> F
    T5 --> F

    F --> F1["Сузить фильтр"]
    F --> F2["Открыть источник"]
    F --> F3["Сравнить с другим режимом"]
    F --> F4["Сгенерировать гипотезу"]
    F --> F5["Оценить ответ: полезно / неверно / не хватает"]

    F1 --> P
    F3 --> P
    F4 --> M4
    F5 --> LOG["Feedback log для оценки и улучшения retrieval"]
