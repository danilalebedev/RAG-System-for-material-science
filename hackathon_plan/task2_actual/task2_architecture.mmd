flowchart TD
    A["Yandex Disk corpus<br/>1453 files, ~4.98 GB"] --> B["File registry<br/>hash, type, section, path"]
    B --> C["Parsers<br/>PDF, DOCX/DOCM, PPTX, XLS/XLSX, archives"]
    C --> D["Chunks + tables + slides<br/>page/section/source provenance"]

    D --> E1["Full-text index<br/>BM25 / FTS"]
    D --> E2["Vector index<br/>embeddings"]
    D --> E3["Typed metadata extraction<br/>numeric, geo, dates, units"]
    D --> E4["LLM extraction<br/>entities, claims, procedure summaries"]

    E3 --> F["Normalized metadata store<br/>DuckDB/Postgres"]
    E4 --> F
    E4 --> G["Knowledge graph<br/>Experiment-centric nodes/edges"]

    U["User query"] --> Q["Query parser<br/>intent + slots"]
    Q --> QF["Filters<br/>numeric, geo, version, source"]
    Q --> R["Hybrid retrieval planner"]

    E1 --> R
    E2 --> R
    F --> R
    G --> R
    QF --> R

    R --> RR["Rerank<br/>semantic + lexical + typed + graph"]
    RR --> P["Evidence pack<br/>chunks + tables + triples + citations"]
    P --> L["LLM / template answer composer"]
    L --> O["UI result<br/>Answer | Evidence | Graph | Gaps | Export"]

    O --> AUD["Audit log + feedback"]
    O --> EXP["Export<br/>CSV, JSON, GraphML, PNG/PDF report"]
