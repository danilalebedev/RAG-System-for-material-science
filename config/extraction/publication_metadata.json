{
  "model_uri_template": "gpt://{folder_id}/yandexgpt-5.1/latest",
  "fallback_model_uri_template": "gpt://{folder_id}/yandexgpt-lite/latest",
  "completion_endpoint": "https://llm.api.cloud.yandex.net/foundationModels/v1/completion",
  "temperature": 0.1,
  "max_tokens": 6500,
  "request_timeout_seconds": 120,
